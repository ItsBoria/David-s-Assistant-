# Supabase public configuration (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-the-project-anon-or-publishable-key

# Supabase trusted-server configuration (never expose in browser code)
SUPABASE_SERVICE_ROLE_KEY=replace-with-the-service-role-key

# Telegram trusted-server configuration (Phase 6; intentionally inactive in Phase 1)
TELEGRAM_BOT_TOKEN=replace-with-the-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
TELEGRAM_BOT_USERNAME=replace-with-the-bot-username

# Application configuration
# Must be the canonical HTTPS origin in production; HTTP is accepted only for loopback development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE_DEFAULT=Asia/Jerusalem
CRON_SECRET=replace-with-a-random-cron-secret
